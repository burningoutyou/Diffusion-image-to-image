{
    "name": "layout_train",
    "gpu_ids": [0],
    "seed": -1,
    "finetune_norm": false,

    "path": {
        "base_dir": "experiments",
        "code": "code",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
    },

    "datasets": {
        "train": {
            "which_dataset": {
                "name": ["data.dataset", "LayoutCondPairDataset"],
                "args": {
                    "data_root": "dataset/train",
                    "cond_suffix": "_cond",
                    "data_len": -1,
                    "layout_threshold": 0.5,
                    "range_threshold": 0.03,
                    "image_size": [256, 256]
                }
            },
            "dataloader": {
                "validation_split": 0,
                "args": {
                    "batch_size": 2,
                    "num_workers": 0,
                    "shuffle": true,
                    "pin_memory": false,
                    "drop_last": false
                },
                "val_args": {
                    "batch_size": 2,
                    "num_workers": 0,
                    "shuffle": false,
                    "pin_memory": false,
                    "drop_last": false
                }
            }
        },
        "test": {
            "which_dataset": {
                "name": ["data.dataset", "LayoutCondPairDataset"],
                "args": {
                    "data_root": "dataset/train",
                    "cond_suffix": "_cond",
                    "data_len": -1,
                    "layout_threshold": 0.5,
                    "range_threshold": 0.03,
                    "image_size": [256, 256]
                }
            },
            "dataloader": {
                "args": {
                    "batch_size": 2,
                    "num_workers": 0,
                    "pin_memory": false
                }
            }
        }
    },

    "model": {
        "which_model": {
            "name": ["models.model", "Palette"],
            "args": {
                "sample_num": 2,
                "task": "colorization",
                "ema_scheduler": {
                    "ema_start": 1,
                    "ema_iter": 1,
                    "ema_decay": 0.9999
                },
                "optimizers": [
                    { "lr": 1e-4, "weight_decay": 0}
                ]
            }
        },
        "which_networks": [
            {
                "name": ["models.network", "Network"],
                "args": {
                    "init_type": "kaiming",
                    "module_name": "guided_diffusion",
                    "unet": {
                        "in_channel": 4,
                        "out_channel": 1,
                        "inner_channel": 32,
                        "channel_mults": [1, 2, 4],
                        "attn_res": [16],
                        "num_head_channels": 32,
                        "res_blocks": 1,
                        "dropout": 0.0,
                        "image_size": 256
                    },
                    "beta_schedule": {
                        "train": {
                            "schedule": "linear",
                            "n_timestep": 1000,
                            "linear_start": 1e-6,
                            "linear_end": 0.01
                        },
                        "test": {
                            "schedule": "linear",
                            "n_timestep": 500,
                            "linear_start": 1e-4,
                            "linear_end": 0.09
                        }
                    }
                }
            }
        ],
        "which_losses": ["mse_loss"],
        "which_metrics": ["mae"]
    },

    "train": {
        "n_epoch": 999,
        "n_iter": 1e8,
        "val_epoch": 1000,
        "save_checkpoint_epoch": 100,
        "log_iter": 100,
        "tensorboard": true
    },

    "debug": {
        "val_epoch": 1,
        "save_checkpoint_epoch": 1,
        "log_iter": 10,
        "debug_split": 50
    }
}
